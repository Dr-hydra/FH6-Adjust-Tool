<local:MyPageRight x:Class="PageSavedTunes"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:QING.UIKIT"
                   PanScroll="PanBack">
    <local:MyScrollViewer x:Name="PanBack"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,14">
            
            <!-- 导入分享码 -->
            <local:MyCard x:Name="CardImport" Title="导入分享码" Margin="0,0,0,15">
                <Grid Margin="20,40,20,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <local:MyTextBox x:Name="TxtImportCode" Grid.Column="0"
                                         HintText="粘贴分享码 (FH6v1:...)"
                                         Height="34" Margin="0,0,10,0" />
                        <local:MyButton x:Name="BtnImport" Grid.Column="1"
                                        Text="导入" Height="34"
                                        Padding="18,0,18,0"
                                        ToolTip="解析分享码并添加到列表" />
                    </Grid>
                </Grid>
            </local:MyCard>

            <!-- 调校列表 -->
            <local:MyCard x:Name="CardList" Title="调校方案列表" Margin="0">
                <StackPanel Margin="20,40,20,18">
                    <TextBlock x:Name="LabNoTunes" Text="暂无保存的调校方案。您可以在“调校计算”页面完成参数计算后，为方案命名并保存到此处。" 
                               Foreground="{DynamicResource ColorBrushGray2}" HorizontalAlignment="Center" Margin="0,30" FontSize="13" TextWrapping="Wrap" Visibility="Collapsed" />
                    
                    <StackPanel x:Name="PanelTunesList" />
                </StackPanel>
            </local:MyCard>

        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
