<local:MyPageRight x:Class="PageSettings"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:QING.UIKIT"
                   PanScroll="PanBack">
    <local:MyScrollViewer x:Name="PanBack"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,14">
            
            <!-- 计量单位 -->
            <local:MyCard x:Name="CardUnits" Title="计量单位" Margin="0,0,0,15">
                <StackPanel Margin="20,40,20,18">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="重量单位" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyComboBox x:Name="ComboUnitWeight" Grid.Column="1" Height="34" />
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="速度单位" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyComboBox x:Name="ComboUnitSpeed" Grid.Column="1" Height="34" />
                    </Grid>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="胎压单位" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyComboBox x:Name="ComboUnitPressure" Grid.Column="1" Height="34" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="悬挂弹簧单位" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyComboBox x:Name="ComboUnitSprings" Grid.Column="1" Height="34" />
                    </Grid>
                </StackPanel>
            </local:MyCard>

            <!-- 遥测数据 -->
            <local:MyCard x:Name="CardTelemetry" Title="遥测数据" Margin="0,0,0,15">
                <StackPanel Margin="20,40,20,18">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="UDP 监听地址" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtTelemetryHost" Grid.Column="1" Height="34"
                                         HintText="127.0.0.1"
                                         local:SettingService.Key="TelemetryUdpHost" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="UDP 端口" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtTelemetryPort" Grid.Column="1" Height="34"
                                         HintText="5400"
                                         local:SettingService.Key="TelemetryUdpPort" />
                    </Grid>
                    <local:MyCheckBox x:Name="ChkTelemetryAutoStart"
                                      Text="打开遥测页时自动开始监听"
                                      local:SettingService.Key="TelemetryAutoStart"
                                      Margin="0,2,0,8" />
                    <TextBlock Text="在游戏的 Data Out 设置中填写同一地址和端口，仪表、圈速、路线和问题标记会写入同一个 telemetry.db。"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource ColorBrushGray3}" />
                </StackPanel>
            </local:MyCard>

            <!-- AI 智能服务配置 -->
            <local:MyCard x:Name="CardApiKey" Title="AI 智能接口配置" Margin="0,0,0,15">
                <StackPanel Margin="20,40,20,18">
                    <!-- 接口供应商 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AI 供应商" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyComboBox x:Name="ComboAiProvider" Grid.Column="1" Height="34" />
                    </Grid>

                    <!-- API 密钥 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabApiKeyTitle" Text="API 密钥 (API Key)" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtAiApiKey" Grid.Column="1" Height="34" />
                    </Grid>

                    <!-- 自定义接口地址 (仅在 OpenAI-Compatible 时显示) -->
                    <Grid x:Name="GridCustomUrl" Margin="0,0,0,14" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="接口地址 (Base URL)" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtAiCustomUrl" Grid.Column="1" Height="34" HintText="例如 https://api.deepseek.com/v1" />
                    </Grid>

                    <!-- 运行模型 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="运行模型" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyComboBox x:Name="ComboAiModel" Grid.Column="1" Height="34" />
                    </Grid>

                    <!-- 自定义模型名称 (仅在选择自定义模型时显示) -->
                    <Grid x:Name="GridModelCustom" Margin="0,0,0,14" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="自定义模型名称" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtAiModelCustom" Grid.Column="1" Height="34" HintText="例如 deepseek-chat" />
                    </Grid>

                    <!-- 测试与状态 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabKeyStatus" Text="未检测到配置密钥" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrushGray2}" FontSize="12" />
                        <local:MyLoading x:Name="LoadKey" Grid.Column="1" Height="28" Width="28" AutoRun="False" Margin="12,0" VerticalAlignment="Center" />
                        <local:MyButton x:Name="BtnTestKey" Grid.Column="2" Text="测试并保存配置" Padding="14,6" Height="34" ColorType="Highlight" VerticalAlignment="Center" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource ColorBrushBorder}" Margin="0,5,0,12" />
                    <TextBlock Text="注意：" FontWeight="SemiBold" Foreground="{DynamicResource ColorBrushGray3}" FontSize="11" Margin="0,0,0,4" />
                    <TextBlock Text="1. 您的 API Key 将只存储在本地电脑上，不会发送给除您指定的官方或代理接口以外的任何第三方服务器。" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ColorBrushGray2}" Margin="0,0,0,2" />
                    <TextBlock Text="2. Gemini 提供商免费额度高，如需配置国内的 DeepSeek / 百度 / 阿里等大模型，请选择 OpenAI 兼容接口，并配置正确的 API 密钥和 Base URL。" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ColorBrushGray2}" />
                </StackPanel>
            </local:MyCard>

            <!-- 主题配色设置 -->
            <local:MyCard x:Name="CardThemeColors" Title="主题配色选择" Margin="0,0,0,15">
                <StackPanel Margin="20,40,20,18">
                    <TextBlock Text="界面颜色与预设方案" FontWeight="SemiBold" Foreground="{DynamicResource ColorBrush3}" Margin="0,0,0,6" />
                    <TextBlock Text="您可以直接选择精心预设的配色方案，或者开启“自定义配色”进行精细的 HSL（色调、饱和度、亮度）微调：" FontSize="12" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,12" />
                    
                    <WrapPanel x:Name="PanelPresets" Margin="0,0,0,10">
                        <local:MyRadioBox x:Name="RadioTheme0" Text="经典蓝" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="0" Margin="0,0,16,12" />
                        <local:MyRadioBox x:Name="RadioTheme1" Text="翡翠绿" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="1" Margin="0,0,16,12" />
                        <local:MyRadioBox x:Name="RadioTheme5" Text="炫酷黑" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="5" Margin="0,0,16,12" />
                        <local:MyRadioBox x:Name="RadioTheme7" Text="紫罗兰" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="7" Margin="0,0,16,12" />
                        <local:MyRadioBox x:Name="RadioTheme9" Text="活力橙" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="9" Margin="0,0,16,12" />
                        <local:MyRadioBox x:Name="RadioTheme10" Text="玫瑰红" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="10" Margin="0,0,16,12" />
                        <local:MyRadioBox x:Name="RadioThemeCustom" Text="自定义配色" local:SettingService.Key="UiLauncherTheme" local:SettingService.Value="14" Margin="0,0,16,12" />
                    </WrapPanel>

                    <!-- 自定义 HSL 调色板 -->
                    <StackPanel x:Name="PanCustomHSL" Visibility="Collapsed" Margin="0,8,0,0">
                        <Border Height="1" Background="{DynamicResource ColorBrushBorder}" Margin="0,0,0,16" />
                        <TextBlock Text="自定义 HSL 调色板" FontWeight="SemiBold" Foreground="{DynamicResource ColorBrush3}" Margin="0,0,0,14" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LabHue" Text="色调: 210" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                            <local:MySlider x:Name="SliderHue" Grid.Column="1" Value="210" MaxValue="360" local:SettingService.Key="UiLauncherThemeHue" />
                        </Grid>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LabSat" Text="饱和度: 70%" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                            <local:MySlider x:Name="SliderSat" Grid.Column="1" Value="70" MaxValue="100" local:SettingService.Key="UiLauncherThemeSat" />
                        </Grid>
                        
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LabLight" Text="亮度微调: 0" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                            <local:MySlider x:Name="SliderLight" Grid.Column="1" Value="20" MaxValue="40" local:SettingService.Key="UiLauncherThemeLight" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </local:MyCard>

            <!-- 磨砂与背景设置 -->
            <local:MyCard x:Name="CardThemeBackground" Title="磨砂与背景设置" Margin="0">
                <StackPanel Margin="20,40,20,18">
                    <TextBlock Text="界面透明度与磨砂背景" FontWeight="SemiBold" Foreground="{DynamicResource ColorBrush3}" Margin="0,0,0,6" />
                    <TextBlock Text="调整窗口整体不透明度和控件背景不透明度，或加载自定义背景图片并配置透明度与模糊清晰度。" FontSize="12" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,16" />

                    <!-- 窗口不透明度 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabWindowTrans" Text="窗口不透明度: 100%" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MySlider x:Name="SliderWindowTrans" Grid.Column="1" Value="100" MaxValue="100" local:SettingService.Key="UiLauncherTransparent" />
                    </Grid>
                    
                    <!-- 控件不透明度 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabControlOpacity" Text="控件不透明度: 95%" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MySlider x:Name="SliderControlOpacity" Grid.Column="1" Value="95" MaxValue="100" local:SettingService.Key="UiControlOpacity" />
                    </Grid>

                    <!-- 背景透明度 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabBgOpacity" Text="背景透明度: 28%" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MySlider x:Name="SliderBgOpacity" Grid.Column="1" Value="28" MaxValue="100" local:SettingService.Key="UiBackgroundOpacity" />
                    </Grid>

                    <!-- 背景图片清晰度 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabBgClarity" Text="背景图片清晰度: 100%" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MySlider x:Name="SliderBgClarity" Grid.Column="1" Value="100" MaxValue="100" local:SettingService.Key="UiBackgroundClarity" />
                    </Grid>

                    <Border Background="{DynamicResource ColorBrushSemiTransparent}" CornerRadius="6" Padding="14" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="本地自定义背景图" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ColorBrush3}" />
                                <TextBlock x:Name="LabImagePath" Text="使用默认内置背景图" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,4,12,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <local:MyButton x:Name="BtnSelectBg" Text="选择图片" Margin="0,0,8,0" Padding="14,6" ColorType="Highlight" />
                                <local:MyButton x:Name="BtnResetBg" Text="恢复默认" Padding="14,6" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </local:MyCard>

        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
