<local:MyPageRight x:Class="PageTelemetry"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:QING.UIKIT"
                   xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid Margin="18">
        <Border Background="{DynamicResource ColorBrushBackgroundTransparentSidebar}"
                CornerRadius="6"
                BorderBrush="{DynamicResource ColorBrushHalfWhite}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <wv2:WebView2 x:Name="WebTelemetry"
                          Margin="1"
                          DefaultBackgroundColor="Transparent" />
        </Border>
    </Grid>
</local:MyPageRight>
